{
    "cli": {
        "version": ">= 12.0.0"
    },
    "build": {
        "development": {
            "node": "22.14.0",
            "developmentClient": true,
            "distribution": "internal",
            "android": {
                "gradleCommand": ":app:assembleDebug",
                "buildType": "apk"
            },
            "ios": {
                "simulator": true
            }
        },
        "preview": {
            "node": "22.14.0",
            "distribution": "internal",
            "android": {
                "buildType": "apk"
            },
            "ios": {
                "simulator": false,
                "resourceClass": "m-medium"
            },
            "env": {
                "EXPO_PUBLIC_BACKEND_URL": "https://api-beta-rockit.rockhosting.org"
            }
        },
        "production": {
            "node": "22.14.0",
            "android": {
                "buildType": "apk"
            },
            "ios": {
                "simulator": false,
                "resourceClass": "m-medium"
            }
        }
    },
    "submit": {
        "production": {
            "android": {
                "serviceAccountKeyPath": "./google-services.json",
                "track": "internal"
            },
            "ios": {
                "appleId": "dummy",
                "ascAppId": "dummy",
                "appleTeamId": "dummy"
            }
        }
    }
}

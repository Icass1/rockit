{
  "version": "0.3.0",
  "compounds": [
    {
      "name": "Full Stack (DEBUG)",
      "configurations": [
        "FastAPI Uvicorn (DEBUG)",
        "NextJS Server"
      ]
    },
    {
      "name": "Full Stack",
      "configurations": [
        "FastAPI Uvicorn",
        "NextJS Server"
      ]
    },
    {
      "name": "Full Stack SSH Tunnel",
      "configurations": [
        "SSH Tunnel",
        "FastAPI Uvicorn (DEBUG)",
        "NextJS Server"
      ]
    },
    {
      "name": "Full Stack Mobile (LAN)",
      "configurations": [
        "FastAPI Uvicorn (DEBUG)",
        "NextJS Server",
        "SSH Tunnel",
        "Expo LAN"
      ]
    },
    {
      "name": "Frontend",
      "configurations": [
        "NextJS Server"
      ]
    }
  ],
  "configurations": [
    {
      "name": "FastAPI Uvicorn",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "args": [
        "backend.core.main:app",
        "--host",
        "0.0.0.0",
        "--port",
        "8000"
      ],
      "cwd": "${workspaceFolder}",
      "justMyCode": true
    },
    {
      "name": "FastAPI Uvicorn (DEBUG)",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "args": [
        "backend.core.main:app",
        "--reload",
        "--host",
        "0.0.0.0",
        "--port",
        "8000"
      ],
      "cwd": "${workspaceFolder}",
      "justMyCode": true
    },
    {
      "name": "SSH Tunnel",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "ssh",
      "runtimeArgs": [
        "-L",
        "5433:localhost:5432",
        "-J",
        "gateway@ssh.rockhosting.org",
        "root@rockit.rockhosting.lan"
      ],
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen"
    },
    {
      "name": "NextJS Server",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "cwd": "${workspaceFolder}/frontend",
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen"
    },
    {
      "name": "Expo LAN",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npx",
      "runtimeArgs": [
        "expo",
        "start",
        "--offline"
      ],
      "env": {
        "REACT_NATIVE_PACKAGER_HOSTNAME": "192.168.1.91"
      },
      "cwd": "${workspaceFolder}/frontend/apps/mobile",
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen"
    }
  ]
}
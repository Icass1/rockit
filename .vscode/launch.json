{
    "version": "0.3.0",
    "compounds": [
        {
            "name": "Full Stack Web",
            "configurations": [
                "FastAPI Uvicorn (DEBUG)",
                "NextJS Server"
            ]
        },
        {
            "name": "Full Stack Web (Tunnel)",
            "configurations": [
                "SSH Tunnel",
                "FastAPI Uvicorn",
                "NextJS Server"
            ]
        },
        {
            "name": "Full Stack Mobile",
            "configurations": [
                "FastAPI Uvicorn (DEBUG)",
                "NextJS Server",
                "Expo LAN"
            ]
        },
        {
            "name": "Full Stack Mobile (Tunnel)",
            "configurations": [
                "SSH Tunnel",
                "FastAPI Uvicorn (DEBUG)",
                "NextJS Server",
                "Expo LAN"
            ]
        },
        {
            "name": "Full Stack Mobile + Web",
            "configurations": [
                "FastAPI Uvicorn (DEBUG)",
                "NextJS Server",
                "Expo LAN"
            ]
        },
        {
            "name": "Full Stack Mobile + Web (Tunnel)",
            "configurations": [
                "SSH Tunnel",
                "FastAPI Uvicorn (DEBUG)",
                "NextJS Server",
                "Expo LAN"
            ]
        }
    ],
    "configurations": [
        {
            "name": "FastAPI Uvicorn",
            "type": "debugpy",
            "request": "launch",
            "module": "uvicorn",
            "args": [
                "backend.core.main:app",
                "--host",
                "0.0.0.0",
                "--port",
                "8000"
            ],
            "cwd": "${workspaceFolder}",
            "justMyCode": true
        },
        {
            "name": "FastAPI Uvicorn (DEBUG)",
            "type": "debugpy",
            "request": "launch",
            "module": "uvicorn",
            "args": [
                "backend.core.main:app",
                "--reload",
                "--host",
                "0.0.0.0",
                "--port",
                "8000"
            ],
            "cwd": "${workspaceFolder}",
            "justMyCode": true
        },
        {
            "name": "SSH Tunnel",
            "type": "node",
            "request": "launch",
            "runtimeExecutable": "ssh",
            "runtimeArgs": [
                "-L",
                "5433:localhost:5432",
                "-J",
                "gateway@no-proxy.rockhosting.org",
                "root@rockit.rockhosting.lan"
            ],
            "console": "integratedTerminal",
            "internalConsoleOptions": "neverOpen"
        },
        {
            "name": "NextJS Server",
            "type": "node",
            "request": "launch",
            "runtimeExecutable": "pnpm",
            "runtimeArgs": [
                "run",
                "dev"
            ],
            "cwd": "${workspaceFolder}/frontend",
            "console": "integratedTerminal",
            "internalConsoleOptions": "neverOpen"
        },
        {
            "name": "Expo LAN",
            "type": "node",
            "request": "launch",
            "runtimeExecutable": "npx",
            "runtimeArgs": [
                "expo",
                "start",
                "--offline"
            ],
            "cwd": "${workspaceFolder}/frontend/apps/mobile",
            "console": "integratedTerminal",
            "internalConsoleOptions": "neverOpen"
        }
    ]
}
{
    "extends": "expo/tsconfig.base",
    "compilerOptions": {
        "strict": true,
        "paths": {
            "@/*": ["./*"],
            "@/dto": ["../../packages/shared/src/dto/index.ts"],
            "@/dto/*": ["../../packages/shared/src/dto/*"]
        }
    },
    "include": [
        "**/*.ts",
        "**/*.tsx",
        ".expo/types/**/*.ts",
        "expo-env.d.ts",
        "../../packages/shared/src/dto/*.ts"
    ]
}
